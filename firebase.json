{
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-adminsdk-*.json"
            ]
        }
    ],
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "functions/**",
            "package.json",
            "package-lock.json",
            "task.md",
            "implementation_plan.md",
            "deploy_log.txt",
            "deploy_result.txt",
            "README.md",
            "firestore.rules",
            "firestore.indexes.json"
        ]
    }
}